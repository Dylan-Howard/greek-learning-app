  },
  "DevSettings": {
    "DefaultTestUser": "intermediate",
    "AutoSeedDatabase": false
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Information"
    }
  }
