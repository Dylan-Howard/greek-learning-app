{
  "name": "koine",
  "version": "0.1.0",
  "private": false,
  "homepage": "https://dylan-howard.github.io/Greek-Learning-App/",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "codegen": "graphql-codegen",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:smoke": "playwright test --config=playwright.config.ts --project=smoke",
    "test:e2e": "playwright test --config=playwright.config.ts --project=e2e",
    "test:playwright:install": "playwright install --with-deps",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest",
      "plugin:storybook/recommended"
    ],
    "rules": {
      "react/react-in-jsx-scope": "off",
      "react/jsx-uses-react": "off"
    }
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "dependencies": {
    "@apollo/client": "^3.13.8",
    "@clerk/clerk-react": "^5.61.1",
    "@clerk/nextjs": "^6.38.2",
    "@emotion/cache": "^11.14.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.8",
    "@mui/material": "^7.3.8",
    "@mui/material-nextjs": "^7.3.8",
    "@next/eslint-plugin-next": "^16.1.6",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^10.0.1",
    "graphql": "^16.11.0",
    "graphql-tag": "^2.12.6",
    "next": "^16.1.6",
    "oxlint": "^1.50.0",
    "prettier": "^3.8.1",
    "react": "^19.2.4",
    "react-cookie": "^8.0.1",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1",
    "stylis-plugin-rtl": "^2.1.1",
    "typescript": "^5.9.3",
    "web-vitals": "^5.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.0",
    "@graphql-codegen/cli": "^5.0.7",
    "@graphql-codegen/typescript": "^4.1.6",
    "@graphql-codegen/typescript-operations": "^4.6.1",
    "@graphql-codegen/typescript-react-apollo": "^4.3.2",
    "@storybook/addon-a11y": "^10.3.3",
    "@storybook/addon-docs": "^10.3.3",
    "@playwright/test": "^1.51.1",
    "@vitest/coverage-v8": "^4.0.18",
    "fast-check": "^3.23.2",
    "jsdom": "^28.1.0",
    "eslint-plugin-storybook": "^10.3.3",
    "storybook": "^10.3.3",
    "@storybook/nextjs-vite": "^10.3.3",
    "vite": "^8.0.3",
    "vitest": "^4.0.18"
  }
}
