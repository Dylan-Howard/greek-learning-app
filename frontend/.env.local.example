# ============================================================
# Koine Frontend — Local Environment Variables
# Copy this file to .env.local and fill in real values.
# .env.local is git-ignored and must never be committed.
# ============================================================

# ------------------------------------------------------------
# API URLs
# ------------------------------------------------------------

# Public REST API base URL (used client-side)
NEXT_PUBLIC_API_URL=http://localhost:5001/api

# GraphQL endpoint (defaults to http://localhost:5001/graphql if omitted)
NEXT_PUBLIC_GRAPHQL_URL=http://localhost:5001/graphql

# Internal server-side API base URL (used in RSC / SSR, e.g. inside Docker)
INTERNAL_API_URL=http://localhost:5001

# ------------------------------------------------------------
# Clerk Authentication
# Required — the app will throw a build-time error if
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY is absent.
# Obtain these from your Clerk dashboard → API Keys.
# ------------------------------------------------------------

# Publishable key (safe to expose to the browser)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_<your-publishable-key>

# Secret key (server-side only — never expose to the browser)
CLERK_SECRET_KEY=sk_test_<your-secret-key>

# ------------------------------------------------------------
# Clerk Redirect URLs
# These control where Clerk sends users after auth events.
# ------------------------------------------------------------

# URL of the sign-in page
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/auth/login

# URL of the sign-up page
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/auth/signup

# Where to send users after sign-in (fallback if no redirect param)
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/reader

# Where to force-redirect users after sign-up (overrides any redirect param)
NEXT_PUBLIC_CLERK_SIGN_UP_FORCE_REDIRECT_URL=/onboarding
